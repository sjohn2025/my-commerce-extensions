{
  "meshConfig": {
    "sources": [
      {
        "name": "Commerce",
        "handler": {
          "graphql": {
            "endpoint": "https://na1-sandbox.api.commerce.adobe.com/UPZAQ7XCaXkDzt76o4yD3a/graphql",
            "operationHeaders": {
              "Content-Type": "application/json",
              "Magento-Environment-Id": "<tenant-id>",
              "Magento-Website-Code": "<website-code>",
              "Magento-Store-Code": "<store-code>",
              "Magento-Store-View-Code": "<store-view-code>",
              "Magento-Customer-Group": "<customer-group-code>"
            },
            "schemaHeaders": {
              "Magento-Environment-Id": "<tenant-id>"
            }
          }
        }
      },
      {
        "name": "Enrichment",
        "handler": {
          "openapi": {
            "source": "./enrichment-openapi.json"
          }
        },
        "transforms": [
          {
            "prefix": {
              "value": "Enrichment_",
              "includeRootOperations": true
            }
          }
        ]
      }
    ]
  }
}
